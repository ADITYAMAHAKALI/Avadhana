          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Commitment (1) to (many) CommitmentCheckpoint -->
        <mxCell id="e_commit_ckpt" value="" style="edgeStyle=entityRelationEdgeStyle;dashed=1;html=1;endArrow=ERmany;startArrow=ERone;rounded=0;exitX=1;exitY=0.3;exitDx=0;exitDy=0;entryX=0;entryY=0.3;entryDx=0;entryDy=0;" edge="1" parent="1" source="tbl_commit" target="tbl_ckpt">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Commitment (many) to (1) Problem [external] -->
        <mxCell id="e_commit_problem" value="" style="edgeStyle=entityRelationEdgeStyle;dashed=1;html=1;endArrow=ERone;startArrow=ERmany;rounded=0;exitX=1;exitY=0.15;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;strokeColor=#999999;" edge="1" parent="1" source="tbl_commit" target="tbl_problem">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="1040" y="450" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- ============ NOTES / LEGEND ============ -->
        <mxCell id="note1" value="Every User has exactly 3 FocusSlots (seeded at signup). A slot's commitment_id is set when a Commitment is created and cleared when it resolves/is abandoned, freeing the slot." style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;fontSize=11;fontColor=#666666;fontStyle=2;" vertex="1" parent="1">
          <mxGeometry x="60" y="420" width="360" height="60" as="geometry" />
        </mxCell>

