  <diagram name="Solution Marketplace — Matching Flow" id="flow-marketplace-matching">
    <mxGraphModel dx="1400" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1150" pageHeight="1520" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="n_start" value="RFP published or edited" style="ellipse;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=12;" vertex="1" parent="1"><mxGeometry x="380" y="40" width="260" height="60" as="geometry" /></mxCell>
        <mxCell id="n_enqueue" value="Enqueue matching job
