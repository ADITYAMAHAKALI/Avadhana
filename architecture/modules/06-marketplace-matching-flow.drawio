        <mxCell id="n_done_none" value="Done" style="ellipse;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=12;" vertex="1" parent="1"><mxGeometry x="20" y="850" width="180" height="50" as="geometry" /></mxCell>
        <mxCell id="n_attr" value="Structured attribute-match scoring
