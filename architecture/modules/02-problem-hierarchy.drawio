        <!-- ================= RELATIONSHIPS ================= -->

        <!-- Problem.parent_problem_id self-reference: loop routed OUTSIDE table, right side, into the gap between Problem (ends x=420) and User (starts x=700). Both endpoints exit/enter on Problem's right edge so the line never crosses the table body. -->
        <mxCell id="edgeSelf" value="parent_of" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;dashed=1;endArrow=ERmandOne;startArrow=ERzeroToMany;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=1;entryY=0.5;entryDx=0;entryDy=0;fontSize=11;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="p_row8" target="p_row1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="560" y="255" />
              <mxPoint x="560" y="135" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- Problem.created_by -> User.id : exits Problem right edge, enters User left edge -->
        <mxCell id="edgeCreatedBy" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;dashed=1;endArrow=ERmandOne;startArrow=ERzeroToMany;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" parent="1" source="p_row9" target="u_row1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="620" y="285" />
              <mxPoint x="620" y="150" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- ProblemRelationship.source_problem_id -> Problem.id : exits ProblemRelationship left edge, loops left and up into Problem's bottom-left -->
        <mxCell id="edgeRelSource" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;dashed=1;endArrow=ERmandOne;startArrow=ERzeroToMany;exitX=0;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=1;entryDx=0;entryDy=0;" edge="1" parent="1" source="r_row2" target="tblProblem">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="20" y="680" />
              <mxPoint x="20" y="510" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- ProblemRelationship.target_problem_id -> Problem.id : exits ProblemRelationship right edge, up into Problem's bottom-right -->
        <mxCell id="edgeRelTarget" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;dashed=1;endArrow=ERmandOne;startArrow=ERzeroToMany;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=1;entryY=1;entryDx=0;entryDy=0;" edge="1" parent="1" source="r_row3" target="tblProblem">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="450" y="710" />
              <mxPoint x="450" y="510" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- ProblemRelationship.initiated_by -> User.id : exits ProblemRelationship right edge, travels up the corridor at x=480, then right along y=100 into User's left edge -->
        <mxCell id="edgeRelUser" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;dashed=1;endArrow=ERmandOne;startArrow=ERzeroToMany;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" parent="1" source="r_row5" target="tblUser">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="500" y="770" />
              <mxPoint x="500" y="100" />
              <mxPoint x="700" y="100" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- TierReclassification.problem_id -> Problem.id : exits TierReclassification left edge, along y=395 corridor (between Problem bottom y=510 and TierReclass top y=440... actually route above TierReclass, through the gap y=400-440) into Problem's right edge -->
        <mxCell id="edgeTierProblem" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;dashed=1;endArrow=ERmandOne;startArrow=ERzeroToMany;exitX=0;exitY=0.5;exitDx=0;exitDy=0;entryX=1;entryY=0.5;entryDx=0;entryDy=0;" edge="1" parent="1" source="t_row2" target="p_row6">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="640" y="470" />
              <mxPoint x="640" y="405" />
              <mxPoint x="420" y="405" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- TierReclassification.proposed_by -> User.id : exits TierReclassification right edge, up the right-side corridor into User's bottom edge -->
        <mxCell id="edgeTierUser" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;dashed=1;endArrow=ERmandOne;startArrow=ERzeroToMany;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0.75;entryY=1;entryDx=0;entryDy=0;" edge="1" parent="1" source="t_row5" target="tblUser">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="1080" y="590" />
              <mxPoint x="1080" y="200" />
              <mxPoint x="865" y="200" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- MergeConflict.problem_relationship_id -> ProblemRelationship.id : clean vertical top-entry, offset to the left of the header center so arrowhead lands on empty header space, not the PK row -->
        <mxCell id="edgeConflictRel" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;dashed=1;endArrow=ERmandOne;startArrow=ERzeroToMany;exitX=0.3;exitY=0;exitDx=0;exitDy=0;entryX=0.3;entryY=1;entryDx=0;entryDy=0;" edge="1" parent="1" source="c_row2" target="tblRel">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- MergeConflict.resolved_by -> User.id : exits MergeConflict right edge, up the far-right corridor into User's left edge (below the PK/id row height, since table is only 1 row tall this still lands on the row but offset left of center avoids the id text) -->
        <mxCell id="edgeConflictUser" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;dashed=1;endArrow=ERzeroToOne;startArrow=ERzeroToMany;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.8;entryDx=0;entryDy=0;" edge="1" parent="1" source="c_row5" target="tblUser">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="540" y="970" />
              <mxPoint x="540" y="60" />
              <mxPoint x="680" y="60" />
              <mxPoint x="680" y="168" />
            </Array>
          </mxGeometry>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
