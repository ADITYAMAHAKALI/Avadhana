          <mxGeometry x="190" y="530" width="220" height="70" as="geometry"/>
        </mxCell>
        <mxCell id="modmodule" value="Moderation logic&#10;(module inside Backend API&#10;initially — split out later)" style="rounded=1;dashed=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="480" y="530" width="220" height="70" as="geometry"/>
