        <mxCell id="cdn" value="DNS / CDN (Cloudflare)&#10;DDoS protection, TLS edge" style="rounded=1;dashed=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="380" y="160" width="220" height="60" as="geometry"/>
