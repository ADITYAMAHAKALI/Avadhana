          <mxGeometry x="370" y="280" width="240" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="nginx" value="Nginx Reverse Proxy&#10;TLS (Let's Encrypt), routing" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="370" y="400" width="240" height="70" as="geometry"/>
