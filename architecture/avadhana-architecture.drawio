        <mxCell id="m20" value="Confirmation - slot spent, clock started" style="html=1;verticalAlign=bottom;endArrow=block;curved=0;rounded=0;exitX=0;exitY=0.6433;entryX=1;entryY=0.5758;" edge="1" parent="1" source="act10" target="act11">
