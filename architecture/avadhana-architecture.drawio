<diagram id="deploy" name="6. Deployment - Solo-Dev Scalable Setup">
    <mxGraphModel dx="1400" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1300" pageHeight="1250" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- VPS boundary -->
        <mxCell id="vpsbound" value="VPS — Docker Compose (single host)" style="rounded=0;dashed=1;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#999999;verticalAlign=top;align=left;spacingLeft=10;spacingTop=4;fontColor=#999999;fontStyle=1;fontSize=12;" vertex="1" parent="1">
