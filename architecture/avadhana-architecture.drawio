          <mxGeometry x="190" y="660" width="220" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="redis" value="Redis&#10;(broker + cache)" style="shape=cylinder3;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;boundedLbl=1;" vertex="1" parent="1">
          <mxGeometry x="470" y="655" width="180" height="90" as="geometry"/>
        </mxCell>

        <!-- Data tier -->
