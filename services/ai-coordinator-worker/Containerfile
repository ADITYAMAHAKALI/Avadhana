# syntax=docker/dockerfile:1
FROM python:3.12-slim

WORKDIR /app

# Install dependencies first for better layer caching
COPY pyproject.toml ./
RUN pip install --no-cache-dir .

# Copy worker code (composition root + interface/impl packages)
COPY worker.py ./
COPY interfaces/ ./interfaces/
COPY impl/ ./impl/

# No exposed port — this is a background job-queue worker, not an HTTP service.
CMD ["python", "worker.py"]
