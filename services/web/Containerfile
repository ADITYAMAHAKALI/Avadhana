# syntax=docker/dockerfile:1
FROM node:22-alpine AS build
WORKDIR /app

COPY package.json package-lock.json ./
RUN npm install

COPY . .
RUN npm run build

FROM nginx:1.27-alpine
COPY --from=build /app/dist /usr/share/nginx/html
COPY nginx.conf /etc/nginx/conf.d/default.conf

# Run as the image's existing unprivileged `nginx` user (uid 101 / gid
# 101 — already baked into this base image, no need to create a new
# one) rather than root — see issue #85. The stock image normally
# starts its master process as root and only drops worker processes to
# `nginx`; running the master itself as non-root needs three things
# nginx otherwise assumes root can set up for it:
#   1. Remove the top-level `user nginx;` directive — nginx refuses to
#      start if a non-root master tries to setuid to a user it's
#      already running as.
#   2. Redirect the pid file from /run (root-owned) to a path under
#      /tmp, which every container user can write to without any
#      extra chown.
#   3. chown the paths nginx writes at runtime — /var/cache/nginx
#      (proxy/fastcgi temp dirs) and /var/log/nginx (access/error
#      logs) — to the nginx user; both are root-owned in the base
#      image. /usr/share/nginx/html only needs to be *readable*, which
#      it already is (mode 0755, world-readable) since the build stage
#      copies it in as root — no chown needed there.
RUN sed -i '/^user  nginx;/d' /etc/nginx/nginx.conf \
    && sed -i 's#pid\s*/run/nginx.pid;#pid /tmp/nginx.pid;#' /etc/nginx/nginx.conf \
    && chown -R nginx:nginx /var/cache/nginx /var/log/nginx
USER nginx

EXPOSE 8082

CMD ["nginx", "-g", "daemon off;"]
