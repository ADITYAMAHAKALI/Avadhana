# Copy this file to .env.local (gitignored via the *.local rule in .gitignore)
# and fill in real values to point the app at a live backend-api.
#
# Leave VITE_API_BASE_URL unset (or delete your .env.local) to run against
# mock/fixture data instead — this is the default for `npm run dev` with no
# .env file at all, so the app never hard-breaks for frontend-only work.

# Base URL of services/backend-api. When port-forwarding the in-cluster
# service for local dev, this is typically http://localhost:8000.
VITE_API_BASE_URL=http://localhost:8000

# Optional: force mock data even when VITE_API_BASE_URL is set above.
# Useful if you want to keep testing UI against fixtures in one terminal
# while pointing another checkout at a live backend. Defaults to false.
# VITE_USE_MOCK_DATA=true
