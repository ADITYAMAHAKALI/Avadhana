# syntax=docker/dockerfile:1
FROM python:3.12-slim

WORKDIR /app

# Runtime deps for psycopg (v3) building/linking against libpq. Kept
# minimal (no build-essential) since psycopg[binary] ships its own wheel
# with libpq bundled — this is just for anything that needs a C
# toolchain transitively. Cheap insurance, removed from the final layer
# isn't attempted here since this is a single-stage dev/CI image, not a
# hardened production image.
RUN apt-get update && apt-get install -y --no-install-recommends \
    libpq5 \
    && rm -rf /var/lib/apt/lists/*

# Install the package (and its pinned dependency list) directly from
# pyproject.toml, rather than hand-duplicating the dependency list here
# — avoids the two drifting out of sync as real deps (SQLAlchemy,
# Alembic, psycopg, etc.) were added.
COPY pyproject.toml ./
COPY app/ ./app/
RUN pip install --no-cache-dir .

# Alembic config + migrations, so `alembic upgrade head` can be run
# from inside the container (e.g. as a k8s Job or manual exec) against
# DATABASE_URL.
COPY alembic.ini ./
COPY migrations/ ./migrations/

EXPOSE 8000

CMD ["uvicorn", "app.main:app", "--host", "0.0.0.0", "--port", "8000"]
