# syntax=docker/dockerfile:1
FROM python:3.12-slim

WORKDIR /app

# Install dependencies first for better layer caching.
# Installed directly (not via `pip install .`) so we don't need the
# app/ source tree present at this layer, and don't need a package
# build backend to resolve project metadata.
COPY pyproject.toml ./
RUN pip install --no-cache-dir "fastapi>=0.115,<1.0" "uvicorn[standard]>=0.30,<1.0"

# Copy application code
COPY app/ ./app/

EXPOSE 8000

CMD ["uvicorn", "app.main:app", "--host", "0.0.0.0", "--port", "8000"]
