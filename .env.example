# Environment variables for both local dev (Kubernetes-via-Podman, see CLAUDE.md
# "Local Development Environment") and the SLC v1 VPS pilot (docker-compose.prod.yml,
# see docs/vps-deployment.md). Same variable names are reused across both so there is
# one source of truth — a few prod-only vars are called out below.
# Copy to .env and fill in real values. .env is gitignored and must never be committed.
# Locally these are sourced into k8s Secrets (see issue #50); on the VPS, docker compose
# reads .env directly; in CI, values come from env vars/secrets directly.

# --- General ---
ENVIRONMENT=development
LOG_LEVEL=debug

# --- Postgres (local k8s StatefulSet, see issue #45) ---
POSTGRES_HOST=postgres.avadhana-dev.svc.cluster.local
POSTGRES_PORT=5432
POSTGRES_DB=avadhana
POSTGRES_USER=avadhana
POSTGRES_PASSWORD=changeme
DATABASE_URL=postgresql://avadhana:changeme@postgres.avadhana-dev.svc.cluster.local:5432/avadhana

# --- Redis (local k8s Deployment, see issue #46; also used as job queue broker) ---
REDIS_HOST=redis.avadhana-dev.svc.cluster.local
REDIS_PORT=6379
REDIS_URL=redis://redis.avadhana-dev.svc.cluster.local:6379/0

# --- Backend API ---
BACKEND_API_PORT=8000
JWT_SECRET=changeme

# --- AI Coordinator Worker ---
AI_COORDINATOR_INVOCATION_INTERVAL_HOURS=6

# --- SARVAM AI ---
# Leave SARVAM_USE_MOCK=true for local dev/CI so no live API credentials or cost are required (see issue #51).
# When true, the ai-coordinator-worker talks to SARVAM_MOCK_BASE_URL instead of the real API below.
SARVAM_API_KEY=
SARVAM_API_BASE_URL=https://api.sarvam.ai
SARVAM_MOCK_BASE_URL=http://sarvam-mock.avadhana-dev.svc.cluster.local:8080
SARVAM_CHAT_MODEL=sarvam-105b
SARVAM_USE_MOCK=true

# --- Moderation service ---
MODERATION_SERVICE_PORT=8001

# --- Kubernetes context (informational, for scripts/Makefile in issue #52) ---
KUBE_NAMESPACE=avadhana-dev
KUBE_CONTEXT=kind-avadhana-dev

# --- VPS / prod deployment (docker-compose.prod.yml, see docs/vps-deployment.md) ---
# These are only used by the single-VPS Docker Compose pilot deploy, not by
# local k8s dev. Same rule applies: never commit real values.

# Allowed browser origin for the Backend API's CORS policy in production
# (e.g. https://avadhana.example.com). No CORS middleware exists yet in the
# backend-api skeleton (verified — it's currently just `/` + `/healthz`);
# this var is here so the name is reserved and documented for whoever wires
# CORS up alongside real endpoints. Leave blank for local dev.
CORS_ALLOWED_ORIGIN=

# Public DNS name and contact email for the OPTIONAL Caddy edge/reverse-proxy
# service in docker-compose.prod.yml (commented out by default — see that
# file's "Optional: edge reverse proxy / TLS termination" section and
# docs/vps-deployment.md). Only needed if you enable the `edge` service for
# automatic Let's Encrypt TLS. Leave blank until a real domain is pointed at
# the VPS.
CADDY_DOMAIN=
CADDY_EMAIL=
